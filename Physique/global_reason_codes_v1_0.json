{
  "schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "https://elitefitlab.com/schemas/global-reason-codes-registry-v1.0.json",
  "title": "EFL Global Reason Codes Registry v1.0",
  "description": "Centralized registry of all reason codes emitted by EFL validators across DCC-Physique, Tempo Governance, MCC, and R2P systems. Defines namespace, allowed validation passes, severity, and ledger requirements for deterministic enforcement.",
  "version": "1.0.0",
  "date_created": "2026-01-25",
  "enforcement_contract": {
    "rule": "Runtime Shell MUST reject any reason code emitted from a validation pass not in its allowed_passes array.",
    "namespace_enforcement": "All codes are namespaced (DCC/MCC/ADVISORY/R2P). Cross-namespace violations trigger validator bugs.",
    "append_only_policy": "This registry is APPEND-ONLY. Never remove or rename existing codes. Add new codes via formal patch process only.",
    "severity_scale": {
      "1": "NOTE - Informational only, no action required",
      "2": "INFO - Logged for audit trail, may inform future decisions",
      "3": "WARN - Advisory flag, requires attention but not blocking",
      "4": "ALERT - Requires immediate attention, may block or escalate",
      "5": "REJECT - Hard rejection, prescription is illegal"
    }
  },
  "validation_pass_structure": {
    "pass_0": {
      "name": "PARSE",
      "mode": "PRE_LAW"
    },
    "pass_1a": {
      "name": "DCC_LEGALITY",
      "mode": "LAW",
      "authority": "DCC-Physique v1.2"
    },
    "pass_1b": {
      "name": "TEMPO_STRUCTURAL_SAFETY",
      "mode": "LAW",
      "authority": "Tempo Governance v1.1.2"
    },
    "pass_2": {
      "name": "MCC_MODULATION",
      "mode": "CONTEXT",
      "authorities": [
        "MCC v1.0",
        "Tempo Governance v1.1.2"
      ]
    },
    "pass_3": {
      "name": "ADVISORY",
      "mode": "INFORMATIONAL"
    }
  },
  "reason_codes": [
    {
