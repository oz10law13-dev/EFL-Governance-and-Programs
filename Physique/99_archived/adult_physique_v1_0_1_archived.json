{
  "whitelist_version": "1.0.1",
  "eca_version": "ECA-v1.2",
  "population": "adult_physique",
  "description": "Production-hardened exercise whitelist for adult physique clients (intermediate+ training age). Patched to reduce MCC intervention frequency.",
  "date_created": "2026-01-25",
  "changelog": {
    "1.0.1": [
      "Added NODE-3 prohibition policy",
      "Restricted Conventional Deadlift to DAY_A only",
      "Added MCC risk classification to high-risk exercises",
      "Added hinge family H-node clustering hint",
      "Added progression governance reference",
      "Added preferred_block hints to select exercises",
      "Expanded DAY_D carry options",
      "Added hip abduction/rotation isolation exercises",
      "Added selection bias hints"
    ]
  },
  "node_3_policy": {
    "default": "forbidden",
    "requires": [
      "explicit_MCC_opt_in",
      "athlete_readiness_GREEN"
    ],
    "rationale": "NODE 3 is DCC-legal but requires explicit opt-in to prevent generator escalation"
  },
  "progression_governance": {
    "rule": "ONE_AXIS_AT_A_TIME",
    "scope": "per_movement_family_per_week",
    "authority": "DCC-Physique v1.2",
    "rationale": "Generator must not progress multiple exercises in same family on different axes within same week"
  },
  "family_h_node_limits": {
    "hinge": {
      "max_H3_per_week": 1,
      "rationale": "High-eccentric hinge work accumulates rapidly; limit H3 exposure"
    }
  },
